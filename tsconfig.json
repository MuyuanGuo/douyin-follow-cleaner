{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["chrome", "vitest/globals"]
  },
  "include": ["src/**/*.ts", "test/**/*.ts", "playwright/**/*.ts", "vitest.config.ts"]
}
